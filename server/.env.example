PORT=4000
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/notion_clone
CLIENT_ORIGIN=http://localhost:5173
PUBLIC_BASE_URL=http://localhost:4000

# --- JWT ---
# JWT_SECRET is used as a fallback for both access & refresh secrets.
# In production, set JWT_ACCESS_SECRET and JWT_REFRESH_SECRET to two
# distinct long random strings.
JWT_SECRET=replace-with-long-random-string
# JWT_ACCESS_SECRET=
# JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=15m
REFRESH_TTL_DAYS=30
BCRYPT_ROUNDS=12

# --- Cookies ---
# COOKIE_DOMAIN=

# --- Email (console = logs to stdout; swap to smtp/resend in prod) ---
EMAIL_DRIVER=console
EMAIL_FROM=no-reply@notion-clone.local
EMAIL_VERIFICATION_REQUIRED=false

# --- Google OAuth (required to enable "Continue with Google") ---
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create an OAuth 2.0 Client ID (type: Web application)
# 3. Add the redirect URI below to the "Authorized redirect URIs" list
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Redirect URI must be on the CLIENT origin in dev so the refresh cookie
# is stored against the same origin the SPA uses. Vite proxies /api/* to
# the backend, so this URL still hits the backend route handler.
GOOGLE_REDIRECT_URI=http://localhost:5173/api/auth/oauth/google/callback

# --- Storage ---
STORAGE_DRIVER=local
UPLOAD_DIR=uploads

# --- AI (Groq) — Phase 13 ---
# Free, no credit card. Create a key at https://console.groq.com/keys
# AI features (Ask AI, /ai block, autocomplete) auto-disable when this is unset.
GROQ_API_KEY=
# Optional model overrides. Defaults shown below — both are free Groq models.
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_AUTOCOMPLETE_MODEL=llama-3.1-8b-instant
# GROQ_BASE_URL=https://api.groq.com/openai/v1
